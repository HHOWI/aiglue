{
  "name": "@hhowi/aiglue-core",
  "version": "0.4.0",
  "description": "YAML config turns any REST API into an AI-powered natural language interface",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "aiglue": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "assets"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "scripts": {
    "build": "tsc && tsc -p tsconfig.cjs.json && node scripts/post-build-cjs.cjs",
    "build:cjs": "tsc -p tsconfig.cjs.json && node scripts/post-build-cjs.cjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "openai": "^4.77.0",
    "yaml": "^2.8.3",
    "zod-to-json-schema": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0",
    "zod": "^3.22.0"
  },
  "peerDependencies": {
    "express": "^4.0.0 || ^5.0.0",
    "zod": "^3.22.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  }
}
